{
  "info": {
    "_postman_id": "c91dc0ac-f302-482f-82a4-175a066e4cdb",
    "name": "Desafio-QA",
    "description": "Desafio técnico para QA - API de gestão de Pet Shops (Swagger Petstore)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "41103252"
  },
  "item": [
    {
      "name": "REQ-01 - Add a new pet to the store",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Pet tem um ID\", function () {",
              "    pm.expect(pm.response.json().id).to.not.eql(null);",
              "});",
              "",
              "pm.test(\"Salva os dados do pet criado\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.environment.set(\"petId\", jsonData.id);",
              "    pm.environment.set(\"petName\", jsonData.name);",
              "    pm.environment.set(\"petStatus\", jsonData.status);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{$randomInt}},\n  \"category\": {\n    \"id\": {{$randomInt}},\n    \"name\": \"string\"\n  },\n  \"name\": \"doggie\",\n  \"photoUrls\": [\n    \"string\"\n  ],\n  \"tags\": [\n    {\n      \"id\": {{$randomInt}},\n      \"name\": \"string\"\n    }\n  ],\n  \"status\": \"available\"\n}",
          "options": {
            "raw": {
              "headerFamily": "json",
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/pet",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pet"
          ]
        }
      },
      "response": []
    },
    {
      "name": "REQ-02 - Find pet by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Dados do pet batem com o que foi criado\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.eql(Number(pm.environment.get(\"petId\")));",
              "    pm.expect(jsonData.name).to.eql(pm.environment.get(\"petName\"));",
              "    pm.expect(jsonData.status).to.eql(pm.environment.get(\"petStatus\"));",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/pet/{{petId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pet",
            "{{petId}}"
          ]
        },
        "description": "Busca o pet criado no REQ-01 e valida se os dados batem"
      },
      "response": []
    },
    {
      "name": "REQ-03 - Find pet by invalid ID (error)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test(\"Mensagem de erro é 'Pet not found'\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.eql(\"Pet not found\");",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/pet/{{invalidPetId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pet",
            "{{invalidPetId}}"
          ]
        },
        "description": "Busca um id que não existe e valida a mensagem de erro"
      },
      "response": []
    },
    {
      "name": "REQ-04 - Deletes a pet",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 (excluído com sucesso)\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/pet/{{petId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "pet",
            "{{petId}}"
          ]
        }
      },
      "response": []
    }
  ]
}
